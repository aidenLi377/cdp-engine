www.duruo377.top {
	redir https://duruo377.top{uri} permanent
}

duruo377.top {
	encode zstd gzip

	header {
		-Server
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:5000
	}

	handle {
		root * /srv/cdp/current/cdp-web/dist
		try_files {path} /index.html
		file_server
	}
}
