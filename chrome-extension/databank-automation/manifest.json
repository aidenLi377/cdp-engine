{
  "manifest_version": 3,
  "name": "CDP 任务执行器",
  "version": "0.2.0",
  "description": "任务中台本地执行器：DataBank 与 DMP 页面自动化操作。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://databank.tmall.com/*",
    "https://dmp.taobao.com/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:5173/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["dmp_tags_dictionary.json"],
      "matches": ["https://dmp.taobao.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:5173/*", "http://localhost:5173/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://databank.tmall.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://dmp.taobao.com/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://dmp.taobao.com/*"],
      "js": ["dmp-result-core.js", "dmp-content.js"],
      "run_at": "document_idle"
    }
  ]
}
